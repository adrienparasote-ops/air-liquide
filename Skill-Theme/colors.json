{
  "name": "Pyl.Tech Brand",
  "version": "1.1.0",
  "description": "Charte graphique officielle Pyl.Tech",
  "source": "Document officiel charte interne Pyl.Tech",
  "colors": {
    "base": {
      "titlesAndDarkBackground": "#0b132b",
      "slidesBackground": "#ffffff",
      "bodyTextColor": "#4f4f4f",
      "shapeAndGreySlideBackground": "#eeeeee"
    },
    "accents": {
      "primary": "#F4BF46",
      "accent2": "#0d2149",
      "accent3": "#208AAE",
      "accent4": "#5BC0BE"
    },
    "semantic": {
      "success": "#138636",
      "danger": "#C91432"
    },
    "partner": {
      "intelciaPink": "#E91E63"
    }
  },
  "namedColors": {
    "PYL_NAVY_DARK": "#0b132b",
    "PYL_WHITE": "#ffffff",
    "PYL_BODY_GREY": "#4f4f4f",
    "PYL_GREY_BG": "#eeeeee",
    "PYL_YELLOW": "#F4BF46",
    "PYL_NAVY": "#0d2149",
    "PYL_BLUE_TEAL": "#208AAE",
    "PYL_TEAL": "#5BC0BE",
    "PYL_SUCCESS": "#138636",
    "PYL_DANGER": "#C91432"
