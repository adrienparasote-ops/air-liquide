  "typography": {
    "primary": "Poppins",
    "fallbacks": ["Inter", "Montserrat", "DejaVu Sans", "Arial"],
    "officialSizes": {
      "plainText": "12pt",
      "tables": "10pt"
    },
    "sizes": {
      "h1": 28,
      "h2": 20,
      "h3": 18,
      "body": 12,
      "tables": 10,
      "subtitle": 14,
      "footer": 9,
      "kpiLarge": 56,
      "kpiMedium": 32
    },
    "weights": {
      "regular": 400,
      "semibold": 600,
      "bold": 700
    },
    "textColors": {
      "titles": "#0b132b",
      "body": "#4f4f4f",
      "onYellow": "#0b132b",
      "onDark": "#ffffff",
      "footerAndPagination": "#208AAE"
    }
  },
  "spacing": {
    "borderRadiusSm": 2,
    "borderRadiusMd": 4,
    "borderRadiusLg": 8,
    "cardPadding": 24,
    "sectionBadgeSize": 56
  },
