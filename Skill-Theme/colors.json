    "sectionBadge": {
      "background": "#F4BF46",
      "textColor": "#ffffff",
      "size": 56,
      "fontSize": 18,
      "fontWeight": 700,
      "borderRadius": 2
    },
    "titleBlock": {
      "topBorderColor": "#0b132b",
      "bottomBorderColor": "#0b132b",
      "borderWidth": 1
    },
    "footerColor": "#208AAE",
    "cornerBadge": {
      "shape": "triangle",
      "background": "#0b132b",
      "textColor": "#ffffff",
      "rotation": -45
    },
    "highlighter": {
      "background": "#F4BF46",
      "textColor": "#0b132b"
    },
    "bulletStyle": "square",
    "bulletColor": "#F4BF46",
    "bulletSize": 8
